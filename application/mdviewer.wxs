<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="mdviewer"
           Version="$(var.Version)"
           Manufacturer="mdviewer"
           UpgradeCode="F3A8C0E1-2D4B-4A6C-8E0F-1D2B3C4D5E6F">
    <MajorUpgrade DowngradeErrorMessage="A newer version of mdviewer is already installed." />

    <Property Id="ARPPRODUCTICON" Value="app.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/Tonyjh07/mdviewer" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="mdviewer" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="mdviewer">
        <Component Id="StartMenuShortcut" Guid="*">
          <Shortcut Id="AppShortcut"
                    Name="mdviewer"
                    Description="Markdown Reader"
                    Target="[INSTALLFOLDER]mdviewer.exe"
                    WorkingDirectory="INSTALLFOLDER"
                    Icon="app.ico" />
          <RegistryValue Root="HKCU"
                         Key="Software\mdviewer"
                         Name="installed"
                         Value="1"
                         Type="integer"
                         KeyPath="yes" />
          <RemoveFolder Id="RemoveApplicationProgramsFolder"
                        On="uninstall" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main">
      <ComponentGroupRef Id="AppComponents" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>
  </Package>

  <Fragment>
    <Icon Id="app.ico" SourceFile="src-tauri\icons\icon.ico" />
    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="*">
        <File Id="mdviewer.exe"
              Source="src-tauri\target\release\mdviewer.exe"
              KeyPath="yes" />
        <ProgId Id="mdviewer.Markdown"
                Description="Markdown Document"
                Advertise="no">
          <Extension Id="md" ContentType="text/markdown" />
          <Extension Id="markdown" ContentType="text/markdown" />
          <Extension Id="mdown" ContentType="text/markdown" />
        </ProgId>
        <RegistryValue Root="HKCR"
                       Key=".md\OpenWithProgids"
                       Name="mdviewer.Markdown"
                       Value=""
                       Type="string" />
        <RegistryValue Root="HKCR"
                       Key=".markdown\OpenWithProgids"
                       Name="mdviewer.Markdown"
                       Value=""
                       Type="string" />
        <RegistryValue Root="HKCR"
                       Key=".mdown\OpenWithProgids"
                       Name="mdviewer.Markdown"
                       Value=""
                       Type="string" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
